DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
MAX_TOKENS=2048
TEMPERATURE=0.3
ENVIRONMENT=development
# Browser → FastAPI only if you bypass Next and call the API URL directly. Tunnel / forwarded UI
# should use empty NEXT_PUBLIC_API_URL in frontend so /api is same-origin (Next rewrites).
CORS_ORIGINS=http://localhost:3000
